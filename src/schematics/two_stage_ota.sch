C {code_shown.sym} -490 -720 0 0 {name=s1 only_toplevel=false value="
.lib /foss/pdks/sky130A/libs.tech/ngspice/sky130.lib.spice tt
.nodeset v(vout2)=0.9 v(vin2)=0.9 v(vout1)=0.74
.op
.ac dec 20 1 10G
.control
run
setplot ac1
let vdb2 = vdb(vout2)
let vph2 = 180/PI*cph(vout2)
meas ac fu when vdb2=0
meas ac ph_fu find vph2 when vdb2=0
let pm = 180 + ph_fu
print fu pm
plot vdb(vout1) vdb(vout2) xlog
plot vdb2 vph2 xlog
.endc
"
}
